---
import Head from '@components/structure/Head.astro';
import SkipLinks from '@components/structure/SkipLinks.astro';
import Header from '@components/structure/Header.astro';
import Curtain from '@components/Curtain.astro';
import Footer from '@components/structure/Footer.astro';

export interface TransitionAnimation {
  name: string;
  delay?: number | string;
  duration?: number | string;
  easing?: string;
  fillMode?: string;
  direction?: string;
}

export interface TransitionAnimationPair {
  old: TransitionAnimation | TransitionAnimation[];
  new: TransitionAnimation | TransitionAnimation[];
}

export interface TransitionDirectionalAnimations {
  forwards: TransitionAnimationPair;
  backwards: TransitionAnimationPair;
}

interface Props {
  title: string;
  description: string;
  lang?: string;
}

const { title, description, lang = 'en' } = Astro.props;
---

<!doctype html>
<html lang={lang} dir="auto" transition:name="root">
  <Head title={title} description={description} />
  <body>
    <SkipLinks />
    <Header />
    <Curtain />

    <main id="main" tabindex="-1">
      <slot />
    </main>

    <Footer />
  </body>
</html>
