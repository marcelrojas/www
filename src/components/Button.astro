---
interface Props {
  as?: 'button'| 'input';
  type?: 'button' | 'submit' | 'reset';
  action?: 'default' | 'neutral' | 'danger'; // Ajustado a 'default' para hacer match con tu CSS
  size?: 'small' | 'medium' | 'large' | 'full';
  wide?: 'fit' | 'fill';
  disabled?: boolean;
  class?: string;
  text?: string; // ¡Corregido! Faltaba declarar esta prop
  [key: string]: any;
}

const {
  as = 'button',
  type = 'button',
  action = 'default',
  size = 'medium',
  wide = 'fit',
  disabled = false,
  class: userClass,
  text, // Extraemos la prop para que el HTML no de error
  ...rest
} = Astro.props;

const Tag = as === 'input' ? 'input' : 'button';

const attrs: Record<string, any> = {
  ...rest,
  type: type,
  value: as === 'input' ? text : undefined,
  disabled: disabled,
  'aria-disabled': disabled ? 'true' : undefined,
  tabindex: disabled ? -1 : undefined,
};

const classList = [
  'button',
  `action-${action}`,
  `size-${size}`,
  `wide-${wide}`,
  userClass,
].filter(Boolean).join(' ');
---

<Tag
  class={classList}
  {...attrs}
>
  <slot name="text">{text}</slot>
</Tag>

<style is:global>
  @layer components {
    :is(button, input:is([type="button"], [type="submit"], [type="reset"])).button {
      justify-content: center;
      align-items: center;
      display: inline-flex;
      overflow: hidden;
      position: relative;
      z-index: 0;
      width: fit-content;
      height: fit-content;
      font-family: var(--font-family-sans);
      font-weight: var(--font-weight-medium);
      text-transform: uppercase;
      text-align: center;
      text-decoration: none;
      user-select: none;
      touch-action: manipulation;
      transition: background-color 0.15s linear, color 0.15s linear, transform 0.1s linear;
      will-change: background-color, color, opacity, transform;

      &:is(:enabled, [aria-disabled="false"]) {
        cursor: pointer;
        pointer-events: auto;
      }

      &:is(:disabled, [aria-disabled="true"]) {
        cursor: not-allowed;
        pointer-events: none;
        opacity: 0.5;
      }

      &:active:not(:disabled) {

      }

      &:focus-visible {
        outline: 2px solid var(--focus);
        outline-offset: 3px;
      }

      & :is(.symbol, .text):empty {
        display: none;
      }

      &.size-small {
        gap: 3px;
        padding-inline: 10px;
        padding-block: 4px;
        font-size: var(--font-size-12);
        letter-spacing: var(--font-tracking-wide);
        &.wide-full { width: 100%; }
      }

      &.size-medium {
        gap: 4px;
        padding-inline: 14px;
        padding-block: 7px;
        font-size: var(--font-size-14);
        letter-spacing: var(--font-tracking-wide);
        &.wide-full { width: 100%; }
      }

      &.size-large {
        gap: 4px;
        padding-inline: 20px;
        padding-block: 14px;
        font-size: var(--font-size-16);
        letter-spacing: var(--font-tracking-wider);
        &.wide-full { width: 100%; }
      }

      &.action-default {
        background-color: var(--accent);
        color: var(--background-primary);
        fill: var(--background-primary);
        border: 1px solid var(--accent);

        @media (hover: hover) {
          &:hover:not(:disabled, [aria-disabled="true"]) {
            background-color: var(--accent-hover);
            border-color: var(--accent-hover);
          }
        }
      }

      &.action-neutral {
        background-color: transparent;
        color: var(--text-primary);
        fill: var(--text-primary);

        @media (hover: hover) {
          &:hover:not(:disabled, [aria-disabled="true"]) {
            background-color: var(--text-primary);
            color: var(--background-primary);
          }
        }
      }

      &.action-danger {
        background-color: transparent;
        color: oklch(0.6 0.2 25);
        fill: oklch(0.6 0.2 25);
        border: 1px solid oklch(0.6 0.2 25);

        @media (hover: hover) {
          &:hover:not(:disabled, [aria-disabled="true"]) {
            background-color: oklch(0.6 0.2 25);
            color: var(--background-primary);
          }
        }
      }
    }
  }
</style>
