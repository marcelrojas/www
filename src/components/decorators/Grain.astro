<grain-overlay aria-hidden="true">
  <canvas></canvas>
</grain-overlay>

<style>
  grain-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    display: block;
    z-index: 1;
    & canvas {
      width: 100%;
      height: 100%;
      display: block
    }
  }
</style>

<script>
  class GrainOverlay extends HTMLElement {
    constructor() {
      super();
      this.canvas = this.querySelector('canvas');
      this.ctx = this.canvas?.getContext('2d');

      this.patternSize = 64;
      this.patternAlpha = 20;

      this.patternCanvas = document.createElement('canvas');
      this.patternCtx = this.patternCanvas.getContext('2d');
      this.patternData = null;
      this.frameId = null;
      this.observer = null;

      // prevent memory-leaks
      this.animate = this.animate.bind(this);
      this.onResize = this.resize.bind(this);
    }

    // connectedCallback is native on Web Components and get triggered when the Element enter DOM
    connectedCallback() {
      if (!this.canvas) return;

      window.addEventListener('resize', this.onResize);
      this.resize();
      this.createPattern();

      this.observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            this.start();
          } else {
            this.stop();
          }
        });
      });

      this.observer.observe(this);
    }

    // disconnectedCallback, bye-bye memory leaks!
    disconnectedCallback() {
      this.stop();
      window.removeEventListener('resize', this.onResize);
      if (this.observer) this.observer.disconnect();
    }

    start() {
      if (!this.frameId) {
        this.animate();
      }
    }

    stop() {
      if (this.frameId) {
        window.cancelAnimationFrame(this.frameId);
        this.frameId = null;
      }
    }

    resize() {
      this.canvas.width = this.clientWidth * window.devicePixelRatio;
      this.canvas.height = this.clientHeight * window.devicePixelRatio;
    }

    createPattern() {
      this.patternCanvas.width = this.patternSize;
      this.patternCanvas.height = this.patternSize;
      this.patternData = this.patternCtx.createImageData(this.patternSize, this.patternSize);

      const data = this.patternData.data;

      // Uint8ClampedArray prevent Endianness
      for (let i = 0; i < data.length; i += 4) {
        const value = Math.random() * 255;
        data[i]     = value; // Red
        data[i + 1] = value; // Green
        data[i + 2] = value; // Blue
        data[i + 3] = this.patternAlpha; // Alpha
      }

      this.patternCtx.putImageData(this.patternData, 0, 0);
    }

    animate() {
      this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);

      const x = Math.random() * this.patternSize;
      const y = Math.random() * this.patternSize;

      this.ctx.save();
      this.ctx.translate(x, y);

      this.ctx.fillStyle = this.ctx.createPattern(this.patternCanvas, 'repeat');
      this.ctx.fillRect(-x, -y, this.canvas.width + x, this.canvas.height + y);

      this.ctx.restore();

      this.frameId = window.requestAnimationFrame(this.animate);
    }
  }

  // Get the Custom Element. Validation prevent errors on View Transitions
  if (!customElements.get('grain-overlay')) {
    customElements.define('grain-overlay', GrainOverlay);
  }
</script>
