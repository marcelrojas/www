<div id="load-screen" class="loading-hidden">
  <div class="spinner"></div>
</div>

<style is:inline>
  #load-screen {
    position: fixed;
    top: 20px;
    right: 20px;
    z-index: 9999;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
    pointer-events: none;
  }

  #load-screen.loading-visible {
    opacity: 1;
    visibility: visible;
  }

  .spinner {
    width: 24px;
    height: 24px;
    border: 3px solid rgba(255, 255, 255, 0.3);
    border-radius: 50%;
    border-top-color: #fff;
    animation: spin 1s ease-in-out infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }
</style>

<script>
  document.addEventListener('astro:before-preparation', () => {
    document.getElementById('load-screen')?.classList.add('loading-visible');
    document.getElementById('load-screen')?.classList.remove('loading-hidden');
  });

  document.addEventListener('astro:page-load', () => {
    document.getElementById('load-screen')?.classList.remove('loading-visible');
    document.getElementById('load-screen')?.classList.add('loading-hidden');
  });
</script>
