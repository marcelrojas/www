---

<aside role="note">
  <slot />
</aside>

<style is:global>
  aside[role="note"] {
    position: relative;
    padding: var(--spacing-06);
    background-color: oklch(0.95 0.1 240 / 0.3);
    border-left: 4px solid oklch(0.19 0 0);
    border-radius: 8px;
    & p {
      font-size: var(--font-size-16);
      line-height: var(--font-leading-normal);
      color: oklch(0.19 0 0)
    }
  }

  .sidenote {
    padding: 16px;
    border-radius: 10px;
  }

  .sidenote.note {
    background-color: hsl(0, 0%, 96%);
  }

  .sidenote.note dl dt {
    color: hsl(0, 0%, 41%);
  }

  .sidenote.note dl dd {
    color: hsl(0, 0%, 13%);
  }

  .sidenote.info {
    background-color: hsl(0, 0%, 0%);
  }

  .sidenote.warning {
    background-color: hsl(0, 0%, 0%);
    border-color: hsl(0, 0%, 0%);
  }

  .sidenote dl {
    font-family: 'Inter';
    font-size: 14px;
    font-style: normal;
  }

  .sidenote dl dt {
    font-weight: 600;
    line-height: 1.5;
    letter-spacing: -.021em;
  }

  .sidenote dl dd {
    font-weight: 400;
    line-height: 1.4;
    break-inside: avoid;
  }
</style>
