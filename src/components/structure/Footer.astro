---
import Grain from '@components/decorators/Grain.astro';
import Anchor from '@components/Anchor.astro';
import ChamferButton from '@components/ChamferButton.astro';
import { COPYRIGHT_NAME, COPYRIGHT_YEAR } from '@types/consts';

const { encEmail = 'bWFyY2Vscm9qYXMya0BnbWFpbC5jb20=' } = Astro.props;
---

<ChamferButton id="footer-toggle" class="footer-toggle" aria-label="Toggle footer">Further information</ChamferButton>

<footer id="footer" aria-label="Global footer" tabindex="-1">

  <div class="content">

    <aside aria-label="Contact me">
      <div class="">

      </div>

      <ChamferButton id="clipboard-clipper" class="copy-email" data-encemail={encEmail}>Tab to copy my e-mail</ChamferButton>
    </aside>

    <div class="legal">
      <Grain />

      <small class="copyright">&copy; {COPYRIGHT_YEAR} {COPYRIGHT_NAME}. All rights reserved.</small>

      <nav aria-label="Legal">
        <ul>
          <li>
            <Anchor variant="gui2" label="text-only" size="small" href="/colophon">Colophon</Anchor>
          </li>
          <li>
            <Anchor variant="gui2" label="text-only" size="small" href="/impressum">Impressum</Anchor>
          </li>
          <li>
            <Anchor variant="gui2" label="text-only" size="small" href="/privacy-policy">Privacy Policy</Anchor>
          </li>
        </ul>
      </nav>
    </div>

  </div>

</footer>

<style is:global>
  @layer components {
    .footer-toggle {
      position: fixed;
      bottom: 0;
      left: 20%;
      z-index: 90;
      letter-spacing: var(--font-tracking-widest);
      text-align: left;
      display: flex;
      align-items: left;
    }

    footer#footer {
      position: fixed;
      inset: 0;
      z-index: var(--z-footer);
      contain: layout paint;
      content-visibility: auto;
      visibility: hidden;
      background-color: var(--background-primary);

      /* Opened manually */
      body.footer-open & {
        visibility: visible;
        pointer-events: auto;
      }

      /* Standby */
      body.is-standby & {
        visibility: visible;
        pointer-events: auto;
      }

      & > div.content {
        display: flex;
        position: relative;
        height: 100%;

        @media screen and (width <= 768px) {
          flex-direction: column;
        }

        @media screen and (width > 768px) {
          flex-direction: row;
        }

        & > aside {
          position: relative;

          & > span.section-tag {
            font-family: var(--font-family-sans);
            font-weight: var(--font-weight-regular);
            font-size: var(--font-size-12);
            text-transform: uppercase;
          }
        }

        & > div.legal {
          position: relative;
          display: flex;
          gap: var(--spacing-06);
          flex-direction: column;
          align-self: start;
          align-items: baseline;
          padding-inline-start: calc(var(--spacing-sal) + var(--spacing-03));
          padding-inline-end: calc(var(--spacing-sar) + var(--spacing-06));
          padding-block-start: calc(var(--spacing-sat) + var(--spacing-03));
          padding-block-end: calc(var(--spacing-sab) + var(--spacing-02));
          margin-block-end: calc(var(--spacing-sab) + var(--spacing-07));
          border-width: 2px 1px;
          border-style: solid;
          border-color: var(--fill-border);

          & > small.copyright {
            position: relative;
            display: block;
            font-family: var(--font-family-sans);
            font-weight: var(--font-weight-medium);
            font-size: var(--font-size-14);
          }

          & > nav {
            position: relative;
            display: block;
            align-self: start;

            & > ul {
              position: relative;
              display: flex;
              flex-direction: row;
              gap: var(--spacing-04);
              font-size: var(--font-size-12);
            }
          }
        }
      }
    }
  }
</style>

<script client:load src="@scripts/standby.js"></script>
<script client:load src="@scripts/encEmail.js"></script>
