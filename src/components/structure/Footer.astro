---
import Grain from '@components/decorators/Grain.astro';
import Anchor from '@components/Anchor.astro';
import { COPYRIGHT_NAME, COPYRIGHT_YEAR } from '@types/consts';

const { encEmail = 'bWFyY2Vscm9qYXMya0BnbWFpbC5jb20=' } = Astro.props;
---

<button id="footer-toggle" class="footer-toggle" aria-label="Toggle footer">Further information</button>

<footer id="footer" aria-label="Global footer" tabindex="-1">

  <div class="content">

    <aside aria-label="Contact me">
      <span class="section-tag" aria-hidden="true">Tab to copy my e-mail</span>
      <p>Reach out for freelancer work or just to say hi ·[⌢o⌢]·</p>
      <button id="clipboard-clipper" class="copy-email" data-encemail={encEmail}>Tab to copy my e-mail</button>
    </aside>

    <div class="legal">
      <Grain />

      <nav aria-label="Legal">
        <ul>
          <li>
            <a href="/colophon">Colophon</a>
          </li>
          <li>
            <a href="/impressum">Impressum</a>
          </li>
          <li>
            <a rel="privacy-policy" href="/privacy-policy">Privacy Policy</a>
          </li>
        </ul>
      </nav>

      <small class="copyright">&copy; {COPYRIGHT_YEAR} {COPYRIGHT_NAME}. All rights reserved.</small>
    </div>

  </div>

</footer>

<style is:global>
  button.footer-toggle {
    position: fixed;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    z-index: 90;
    background: var(--background-primary);
    color: var(--text-secondary);
    border: 1px solid var(--separator-opaque);
    border-bottom: none;
    font-family: var(--font-family-mono);
    font-size: var(--font-size-12);
    letter-spacing: var(--font-tracking-widest);
    padding: 4px 16px;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: color 0.2s, transform 0.2s;

    &:hover {
      color: var(--accent);
      transform: translateX(-50%) translateY(-2px);
    }
  }

  footer#footer {
    position: fixed;
    inset: 0;
    z-index: var(--z-footer);
    contain: layout paint;
    content-visibility: auto;
    visibility: hidden;
    background-color: var(--background-primary);

    & > div.content {
      display: flex;
      position: relative;
      height: 100%;

      @media screen and (width <= 768px) {
        flex-direction: column;
      }

      @media screen and (width > 768px) {
        flex-direction: row;
      }

      & > aside {
        position: relative;

        & > span.section-tag {
          font-family: var(--font-family-sans);
          font-weight: var(--font-weight-regular);
          font-size: var(--font-size-12);
          text-transform: uppercase;
        }
      }

      & > div.legal {
        position: relative;
        display: flex;
        gap: var(--spacing-06);
        flex-direction: column;
        align-self: end;
        align-items: baseline;
        padding-inline-start: calc(var(--spacing-sal) + var(--spacing-03));
        padding-inline-end: calc(var(--spacing-sar) + var(--spacing-06));
        padding-block-start: calc(var(--spacing-sat) + var(--spacing-03));
        padding-block-end: calc(var(--spacing-sab) + var(--spacing-02));
        border-width: 2px 1px;
        border-style: solid;
        border-color: var(--fill-border);

        & > nav {
          position: relative;
          display: block;
          align-self: end;

          & > ul {
            position: relative;
            display: flex;
            flex-direction: row;
            gap: var(--spacing-04);
            font-family: var(--font-family-sans);
            font-weight: var(--font-weight-regular);
            font-size: var(--font-size-12);
            text-transform: uppercase;
          }
        }

        & > small.copyright {
          position: relative;
          display: block;
          font-family: var(--font-family-sans);
          font-weight: var(--font-weight-medium);
          font-size: var(--font-size-14);
        }
      }
    }
  }

  /* Estado 1: Abierto Manualmente */
  body.footer-open #app-footer {
    visibility: visible;
    pointer-events: auto;
  }
  body.footer-open .footer-content { transform: translateY(0); }
  body.footer-open main { filter: blur(4px); transition: filter 0.4s; }

  /* Estado 2: Modo Inactivo / Standby */
  body.is-standby #app-footer {
    visibility: visible;
    pointer-events: auto;
  }
  body.is-standby .footer-content { transform: translateY(0); }
  body.is-standby main { opacity: 0.3; filter: grayscale(100%) blur(4px); transition: all 0.5s; }
</style>

<script src="@scripts/standby.js"></script>
<script src="@scripts/encEmail.js"></script>
