---
import { ClientRouter } from 'astro:transitions';
import { SITE_TITLE } from '@types/consts';
import '@styles/variables.css';
import '@styles/global.css';

// Tipado más robusto para imágenes (soporta importación local o URL externa)
import type { ImageMetadata } from 'astro';
import Schema from '@components/Schema.astro';

interface Props {
  title: string;
  description: string;
  image?: ImageMetadata | string;
  lang?: string;
}

const FallbackImage = '/og.png';
const {
  title,
  description,
  image = FallbackImage,
  lang = 'en_US'
} = Astro.props;

//const canonicalURL = new URL(Astro.url.pathname.replace(/\/$/, ''), Astro.site);

const pathname = Astro.url.pathname === '/' ? '/' : Astro.url.pathname.replace(/\/$/, '');
const canonicalURL = new URL(pathname, Astro.site);

// Lógica para la imagen Open Graph. Si es una imagen local (ImageMetadata), usar .src; si es string, usarlo directo.
const imageSrc = typeof image === 'string' ? image : image.src;
const ogImageURL = new URL(imageSrc, Astro.site);
---

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>{title}</title>
  <meta name="title" content={title} />
  <meta name="description" content={description} />
  <meta name="generator" content={Astro.generator} />
  <meta name="author" content="Marcel Rojas" />

  <meta name="keywords" content="marcelrojas, whyismarcel, Marcel Rojas, Juan Marcel Rojas Hernández, web developer, designer, maketing specialist, software engineering, Venezuela" />

  <link rel="preload" href="/fonts/InterVariable.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
  <link rel="preload" href="/fonts/GeistMono.woff2" as="font" type="font/woff2" crossorigin="anonymous" />

  <link rel="canonical" href={canonicalURL} />

  <link rel="icon" type="image/svg+xml" sizes="any" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" sizes="32x32" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.svg" />
  <link rel="manifest" href="/manifest.webmanifest" crossorigin="anonymous" />

  <meta name="theme-color" media="(prefers-color-scheme: light)" content="#ffffff" />
  <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#000000" />

  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="alternate" type="application/rss+xml" title={SITE_TITLE} href={new URL('rss.xml', Astro.site)} />
  <link rel="search" type="application/opensearchdescription+xml" title={`Search ${SITE_TITLE}`} href="/opensearch.xml" />
  <link rel="privacy-policy" href="/privacy-policy" />

  <meta name="apple-mobile-web-app-title" content={SITE_TITLE} />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

  <meta property="og:type" content="website" />
  <meta property="og:site_name" content={SITE_TITLE} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageURL} />
  <meta property="og:locale" content={lang} />
  {lang === 'en_US' && <meta property="og:locale:alternate" content="es_VE" />}
  {lang === 'es_VE' && <meta property="og:locale:alternate" content="en_US" />}

  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:creator" content="@whyismarcel" />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content={ogImageURL} />

  <script type="text/partytown" async src="https://www.googletagmanager.com/gtag/js?id=G-42TF8GHE8N"></script>
  <script type="text/partytown">
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-42TF8GHE8N');

    // Integración con View Transitions
    document.addEventListener('astro:page-load', () => {
      gtag('config', 'G-42TF8GHE8N', {
        page_path: window.location.pathname,
      });
    });
  </script>

  <script defer src="/script.js"></script>
  <ClientRouter fallback="animate" />
  <Schema />
</head>
