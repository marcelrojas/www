---
const { screen_title } = Astro.props;
---

<section id="PageHeader">
  <h1>{screen_title}</h1>
</section>

<style is:global>
  section#PageHeader {
    --offset: 80px;
    width: calc(87.5vw - var(--global-scrollbar-buffer, 0px));
    max-width: 1680px;
    margin-inline: auto;
    padding-block: var(--offset);
    display: block;

    @media screen and (width <= 480px) {
      --offset: 56px;
    }

    @media screen and (width <= 734px) {
      --offset: 64px;
    }

    @media screen and (width <= 1068px) {
      --offset: 72px;
    }

    & > h1 {
      max-width: 270px;
      font-size: var();
      font-weight: var(--font-weight-regular);
      line-height: 1.05;
      line-clamp: 2;
      letter-spacing: -.015em;
      text-transform: lowercase;
      color: var(--color-text-primary);
    }
  }
</style>
