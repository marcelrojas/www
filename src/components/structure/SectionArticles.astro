---
import { getCollection, getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import FormattedDate from '@components/FormattedDate.astro';

const posts = (await getCollection('weblog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<section id="post-list" role="feed" aria-busy="false" aria-label="List of blog articles">
  <div class="content">
    <h2>Weblog</h2>
    <p>Thoughts on code, design, and passion for everything. Latest posts and updates.</p>

    {
      posts.map(post => (
        <article class="post-item">
          <a href={`/resources/${post.id}`}>
            <h2>{post.data.title}</h2>
            <p class="description">{post.data.description}</p>
            <div class="metadata">
              <FormattedDate date={post.data.pubDate} />
              <span class="category">{post.data.category}</span>
            </div>
          </a>
        </article>
      ))
    }
  </div>
</section>

<style is:global>
  section#post-list {
    position: relative;
    padding-top: var(--spacing-11);
    padding-bottom: var(--spacing-11);

    & > div.content {
      display: flex;
      flex-direction: column;
      gap: 48px;
      max-width: 980px;
      padding-inline-start: calc(var(--spacing-sal) + 22px);
      padding-inline-end: calc(var(--spacing-sar) + 22px);
      margin-left: auto;
      margin-right: auto;

      & > article.post-item {

        position: relative;
        overflow: hidden;
        user-select: none;

        & > a {
          color: inherit;
          display: block;

          & > h2 {
            max-width: 300px;
            margin: 0 0 8px 0;
            fond-family: var(--font-family-sans);
            font-weight: var(--font-weight-medium);
            font-size: var(--font-size-18);
            line-height: 1;
            line-clamp: 3;
            box-orient: vertical;
            color: var(--label-primary);
          }

          & > p.description {
            margin-top: var(--spacing-02);
            margin-bottom: var(--spacing-04);
            max-width: 300px;
            font-family: var(--font-family-sans);
            font-weight: var(--font-weight-medium);
            font-size: var(--font-size-16);
            line-height: var(--line-height-24);
            line-clamp: 3;
            box-orient: vertical;
            color: var(--label-secondary);
          }

          & > .metadata {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 0.9rem;

            & > span.category {
              border-width: 0 0 0 1px;
              border-style: solid;
              border-color: var(--fill-border);
            }
          }
        }
      }

      & > :first-child { grid-area: a; }
      & > :nth-child(2) { grid-area: b; }
      & > :nth-child(3) { grid-area: c; }
      & > :nth-child(4) { grid-area: d; }
      & > :nth-child(5) { grid-area: e; }
    }
  }
</style>
